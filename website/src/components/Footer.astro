---
/* ---------------------------------------------------------------------------
 * Override: Footer  —  the bottom-of-page area (prev/next nav, edit link,
 * last-updated, and your custom footer content).
 * ---------------------------------------------------------------------------
 * Re-renders Starlight's default footer, then adds your own markup beneath it.
 *
 * To ENABLE: uncomment the `Footer` line in the `components` map in
 * astro.config.mjs.
 *
 * Docs: https://starlight.astro.build/reference/overrides/#footer
 * ------------------------------------------------------------------------- */
import Default from '@astrojs/starlight/components/Footer.astro';
---

<Default><slot /></Default>


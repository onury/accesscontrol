{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "npm",
  "testRunner": "vitest",
  "reporters": ["html", "json", "clear-text", "progress"],
  "jsonReporter": { "fileName": "test/stryker/mutation-report.json" },
  "coverageAnalysis": "perTest",
  "vitest": { "configFile": "vitest.stryker.config.ts" },
  "mutate": [
    "src/**/*.ts",
    "!src/**/index.ts",
    "!src/core/I*.ts",
    "!src/core/UnknownObject.ts"
  ],
  "htmlReporter": { "fileName": "test/stryker/mutation-report.html" },
  "thresholds": { "high": 90, "low": 80, "break": 88 }
}
